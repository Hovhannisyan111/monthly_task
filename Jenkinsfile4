@Library('monthly_task_library') _

pipeline {
    agent any
    environment {
        MONTHLY_DAY = '13'
    }
    stages {
        stage('Build') {
            steps { echo 'Running Build...' }
        }
        stage('Test') {
            steps { echo 'Running Tests...' }
        }
        stage('Package') {
            steps { echo 'Packaging artefacts...' }
        }
        stage('Monthly Task') {
            when {
                expression { return monthlyPipeline5.isMonthlyTaskDue(this) }
            }
            steps {
                script {
                    try {
                        echo 'Running monthly task...'
                        // sh 'aws s3 sync ./dist s3://your-bucket/artifacts'
                        monthlyPipeline5.onSuccess(this)
                    } catch (err) {
                        monthlyPipeline5.onFailure(this)
                        throw err
                    }
                }
            }
        }
    }
    post {
        always { echo "Build finished with: ${currentBuild.currentResult}" }
    }
}
