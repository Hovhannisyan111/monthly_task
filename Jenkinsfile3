@Library('monthly_task_library') _

pipeline {
    agent any
    environment {
        MONTHLY_DAY = '12'
    }
    stages {
        stage('Check Monthly Reset') {
            steps {
                script {
                    monthlyPipeline4.resetIfNewMonth(this)
                }
            }
        }
        stage('Build') {
            steps {
                echo 'Running Build...'
            }
        }
        stage('Test') {
            steps {
                echo 'Running Tests...'
                // error 'Simulated failure'
            }
        }
        stage('Package') {
            steps {
                echo 'Packaging artefacts...'
            }
        }
        stage('Monthly Task') {
            when {
                expression {
                    return monthlyPipeline4.isMonthlyTaskDue(this)
                }
            }
            steps {
                echo 'Running monthly task (sending artifacts to S3)...'
                // sh 'aws s3 sync ./dist s3://your-bucket/artifacts'
            }
            post {
                success { script { monthlyPipeline4.onSuccess(this) } } 
                failure { script { monthlyPipeline4.onFailure(this) } }
            }
        }
    }
    post {
        always {
            echo "Build finished with: ${currentBuild.currentResult}"
        }
    }
}
